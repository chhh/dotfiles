# tm got replaced with a powerful function in .zshrc
# alias tm="tmux"


# tmux config block

alias tmls='tmux list-sessions'
alias tmw='tmux list-windows'
alias tmp='tmux list-panes'

tm() {
  _tm_session_name_from_pwd() {
    basename "$PWD" | sed 's/[^A-Za-z0-9_-]/_/g'
  }

  _tm_has_window() {
    local session="$1"
    local window="$2"
    command tmux list-windows -t "$session" -F '#{window_name}' 2>/dev/null | grep -Fxq "$window"
  }

  _tm_ensure_window() {
    local session="$1"
    local window="$2"
    if ! _tm_has_window "$session" "$window"; then
      command tmux new-window -d -t "$session" -n "$window" -c "$PWD"
    fi
  }

  case "${1-}" in
    "")
      command tmux
      ;;

    a|attach)
      shift
      if [ ! -t 0 ] || [ ! -t 1 ]; then
        echo "tm attach: no tty available"
        return 1
      fi
      if [ "$#" -eq 0 ]; then
        command tmux attach-session
      else
        command tmux attach-session -t "$1"
      fi
      ;;

    d|detach)
      if [ -n "${TMUX:-}" ]; then
        command tmux detach-client
      else
        echo "Not inside tmux"
        return 1
      fi
      ;;

    s|sessions)
      command tmux list-sessions
      ;;

    w|windows)
      if [ "$#" -gt 1 ]; then
        command tmux list-windows -t "$2"
      else
        command tmux list-windows
      fi
      ;;

    p|panes)
      if [ "$#" -gt 1 ]; then
        command tmux list-panes -t "$2"
      else
        command tmux list-panes
      fi
      ;;

    n|new)
      shift
      if [ "$#" -eq 0 ]; then
        command tmux new-session
      else
        command tmux new-session -s "$1"
      fi
      ;;

    nwd)
      name="$(_tm_session_name_from_pwd)"
      command tmux new-session -s "$name" -c "$PWD" -n shell
      ;;

    cwd)
      name="$(_tm_session_name_from_pwd)"

      if ! command tmux has-session -t "$name" 2>/dev/null; then
        command tmux new-session -d -s "$name" -c "$PWD" -n shell
      fi

      if [ -n "${TMUX:-}" ]; then
        command tmux switch-client -t "$name"
      else
        if [ ! -t 0 ] || [ ! -t 1 ]; then
          echo "tm cwd: no tty available for attach"
          return 1
        fi
        command tmux attach-session -t "$name"
      fi
      ;;

    cwd4)
      name="$(_tm_session_name_from_pwd)"

      if ! command tmux has-session -t "$name" 2>/dev/null; then
        command tmux new-session -d -s "$name" -c "$PWD" -n shell
      fi

      _tm_ensure_window "$name" shell
      _tm_ensure_window "$name" run
      _tm_ensure_window "$name" edit
      _tm_ensure_window "$name" ai

      if [ -n "${TMUX:-}" ]; then
        command tmux switch-client -t "$name"
      else
        if [ ! -t 0 ] || [ ! -t 1 ]; then
          echo "tm cwd4: no tty available for attach"
          return 1
        fi
        command tmux attach-session -t "$name"
      fi
      ;;

    *)
      command tmux "$@"
      ;;
  esac
}

# END: tmux config block


