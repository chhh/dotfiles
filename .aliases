alias wd='echo ${PWD##*/}'

# Create a git worktree from a remote or local branch.
# Supports branch names copied from gitk.
wt() {
  if [ -z "$1" ]; then
    echo "Usage: wt <branch-name | remotes/<remote>/<branch>>"
    return 1
  fi

  local input="$1"
  local remote="origin"
  local branch=""
  local ref=""
  local dir=""

  # If input starts with "remotes/", parse remote + branch:
  # regex: remotes\/(.+?)\/(.+)
  if [[ "$input" == remotes/* ]]; then
    remote="$(printf '%s' "$input" | sed -E 's#^remotes/([^/]+)/(.+)$#\1#')"
    branch="$(printf '%s' "$input" | sed -E 's#^remotes/([^/]+)/(.+)$#\2#')"
  else
    branch="$input"
  fi

  dir="../$branch"
  ref="$remote/$branch"

  # Fetch chosen remote (origin by default)
  git fetch "$remote" || return $?

  # If local branch exists, use it; otherwise, use remote ref (will create local branch)
  if git show-ref --verify --quiet "refs/heads/$branch"; then
    git worktree add "$dir" "$branch"
  else
    git worktree add "$dir" "$ref"
  fi
}

nas-create-repo() {
    USERNAME=dima
    HOSTS="192.168.1.191"
    PORT=12022

    REPO=$1

    if [[ -z "${REPO}" ]]; then
        echo "Empty repo name, stopping"
        return 1
    fi

    SCRIPT="cd /volume1/git; mkdir -p ${REPO}; cd ${REPO}; git init --bare;"
    for HOSTNAME in ${HOSTS} ; do
        ssh -l ${USERNAME} -p ${PORT} ${HOSTNAME} "${SCRIPT}"
    done

}

git-add-nas() {
    dir=$1
    cmd="git remote add nas ssh://dima@192.168.1.191:12022/volume1/git/${dir}"
    echo "Cmd: ${cmd}"
    ask-and-run "${cmd}"
    #$(ask-and-stop) && return 0
    #echo "Got throuhgh!"
}

ask-and-stop() {
    read -n 1 -p "Stop now? (y/n)" and;
    printf "\n"
    case $and in
        y|Y)
            echo "Stopping."
            sExit && return 0 
            ;;
        *)
            ;;
    esac
    printf "Proceeding...\n"
}

function die() {
    set -e
    /bin/false
}

function sExit() {
    [ "X$(basename $0 2>/dev/null)" = "X$(basename $BASH_SOURCE)" ] && exit 0 || return 0
}

ask-and-run() {
echo "Command to run:"
echo $1
read -n 1 -p "Would you like to proceed? (y/n/c)" ans;
printf "\n"
case $ans in
    y|Y)
        eval $1
        ;;
    *)
        printf "\nNot running, exiting.\n"
        ;;
esac
}

gkad() {
    gitk --all --date-order
}

gka() {
    gitk --all
}

gkaw() {
    gitk --all --since="$1".weeks
}

gkam() {
    gitk --all --since="$1".months
}

gkgw() {
    gitk --glob="$1" --since="$2".weeks
}

gkgm() {
    gitk --glob="$1" --since="$2".months
}

git_leafs_local() {
        echo "** Below is list of tip branches a.k.a. final nodes."
        echo "** These aren't reachable from any other branches."
        echo "** Removing them is potentially DANGEROUS: it would make some commit unreachable."
        TIPS=$( git rev-list --branches --children | grep -v ' ' | sort )
        { while read branchname commitid message
                do grep $commitid < <(echo $TIPS) -q && echo $branchname
                done
        } < <(git branch -v --no-abbrev | sed 's/\*//' )
        echo "** end of list"
}

git_leafs_origin() {
        echo "** Below is list of tip branches a.k.a. final nodes."
        echo "** These aren't reachable from any other branches."
        echo "** Removing them is potentially DANGEROUS: it would make some commit unreachable."
        TIPS=$( git rev-list --remotes=origin --children | grep -v ' ' | sort )
        { while read branchname commitid message
                do grep $commitid < <(echo $TIPS) -q && echo $branchname
                done
        } < <(git branch -v --no-abbrev | sed 's/\*//' )
        echo "** end of list"
}

git7zbr() {
	echo "** git 7z a specific branch **"
	
	if [ $# -eq 0 ]; then
		echo "No arguments. Need 1 arg - branch name"
		return
	fi

	REPO_NAME=$(basename $(pwd)) && \
	ZIP_NAME=$REPO_NAME.7z && \
	git clone -b $1 . temp_repo && \
	7z a -r $ZIP_NAME ./temp_repo && \
	7z rn $ZIP_NAME temp_repo $REPO_NAME && \
	rm -rf temp_repo && \
	mv $ZIP_NAME ..
}
